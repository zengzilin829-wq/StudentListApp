<!DOCTYPE html>
<html>
<head><title><%= student.name %></title></head>
<body>
  <h1><%= student.name %></h1>
  <img src="<%= student.image %>" width="150"><br>
  <p>Date of Birth: <%= student.dob %></p>
  <p>Contact: <%= student.contact %></p>
  <form action="/deleteStudent/<%= student.studentId %>" method="POST" style="display:inline;">

    <button type="submit" onclick="return confirm('Are you sure you want to delete this student?');">Delete</button>
  </form>
  <br><br>
  <a href="/editStudent/<%= student.studentId %>">Edit</a> | <a href="/">Back to list</a>
</body>
</html>